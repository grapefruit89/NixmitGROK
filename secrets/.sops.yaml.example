# Kopieren nach secrets/.sops.yaml (gitignored) — Stufe 9
# Schema: my.sops.categories in modules/05-sops.nix
creation_rules:
  - path_regex: infra\.yaml$
    key_groups:
      - age:
          - ssh-ed25519  # age-Key des Hosts oder Operators
  - path_regex: media\.yaml$
    key_groups:
      - age:
          - ssh-ed25519